// Este es un ejemplo de Prisma schema para EstetIA
// Ubicación real: backend/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// USUARIOS Y AUTENTICACIÓN
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  password  String   // bcrypt hash
  nombre    String
  apellido  String
  rol       Role     @default(RECEPCIONISTA)
  
  // Para médicos
  especialidad String?
  numeroDocumento String?
  
  // Columnas extendidas (rama paralela)
  username             String?  @unique
  tipoDocumento        String?
  registroMedico       String?
  registroProfesional  String?
  firmaBase64          String?
  
  telefono  String?
  activo    Boolean  @default(true)
  
  // Relaciones
  pacientesCreados Paciente[]
  procedimientosRealizados Procedimiento[]
  historiasEditadas HistoriaClinica[]
  citasAsignadas Cita[]
  auditLogs AuditLog[]
  disponibilidades DisponibilidadMedico[]
  bloqueosAgenda  BloqueDisponibilidad[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([email])
  @@index([rol])
}

enum Role {
  SUPER_ADMIN
  MEDICO
  AUXILIAR
  RECEPCIONISTA
  PACIENTE
}

// ============================================
// PACIENTES (CORE)
// ============================================

model Paciente {
  id                String   @id @default(cuid())
  numeroDocumento   String
  tipoDocumento     String   // CC, CE, PS, PEP
  nombreCompleto    String
  fechaNacimiento   DateTime
  genero            String   // M, F, O
  
  telefonos         String[]
  email             String?
  whatsapp          String?
  
  direccion         String?
  ciudad            String?
  
  alergias          Alergia[]
  medicacionActual  Medicamento[]
  antecedentes      AntecedentesQuirurgicos[]
  
  fotoPerfil        String?
  estado            String   @default("ACTIVO") // ACTIVO, INACTIVO, FALLECIDO
  
  // Relaciones
  procedimientos    Procedimiento[]
  historiasClinicas HistoriaClinica[]
  fotos             FotoClinica[]
  citas             Cita[]
  transacciones     Transaccion[]
  alertas           Alerta[]
  consentimientos   Consentimiento[]
  mapaCorporal      MapaCorporal[]
  seguimientos      SeguimientoPostOp[]
  
  creadoPor         String?
  creadoBy          User?    @relation(fields: [creadoPor], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([numeroDocumento, tipoDocumento])
  @@index([nombreCompleto])
  @@index([estado])
}

model Alergia {
  id          String @id @default(cuid())
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  
  nombre      String
  severidad   String // CRITICA, ALTA, MEDIA, LEVE
  reaccion    String?
  
  @@index([pacienteId])
}

model Medicamento {
  id          String @id @default(cuid())
  pacienteId  String?
  paciente    Paciente? @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  
  nombre      String
  dosis       String
  frecuencia  String
  indicacion  String
  activo      Boolean @default(true)
  
  @@index([pacienteId])
}

model AntecedentesQuirurgicos {
  id          String @id @default(cuid())
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  
  procedimiento String
  fecha       DateTime
  complicaciones String?
  cirujano    String?
  
  @@index([pacienteId])
}

// ============================================
// PROCEDIMIENTOS
// ============================================

model Procedimiento {
  id                      String   @id @default(cuid())
  pacienteId              String
  paciente                Paciente @relation(fields: [pacienteId], references: [id])
  
  medicoId                String
  medico                  User     @relation(fields: [medicoId], references: [id])
  
  // NUEVO: Vinculación con CUPS
  codigoCUPS              String?
  procedimientoCUPS       ProcedimientoCUPS? @relation(fields: [codigoCUPS], references: [codigoCUPS])
  
  tipoProcedimiento       String
  nombreProcedimiento     String
  descripcion             String?
  
  fechaProgramada         DateTime
  fechaRealizada          DateTime?
  
  duracionEstimada        Int      // minutos
  duracionReal            Int?
  
  estado                  String   @default("PENDIENTE") // PENDIENTE, EN_CURSO, COMPLETADO, CANCELADO
  
  notasPreoperatorio      String?
  notasOperatorio         String?
  complicaciones          String[]
  
  resultadoVisualEsperado String?
  resultadoVisualActual   String?
  
  // Relaciones
  historias               HistoriaClinica[]
  fotos                   FotoClinica[]
  consentimientos         Consentimiento[]
  seguimientos            SeguimientoPostOp[]
  alertas                 Alerta[]
  mapaCorporal            MapaCorporal[]
  checklistsCompletados   ChecklistCompletado[]
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  @@index([pacienteId])
  @@index([medicoId])
  @@index([codigoCUPS])
  @@index([estado])
  @@index([fechaProgramada])
}

// ============================================
// HISTORIA CLÍNICA DINÁMICA
// ============================================

model HistoriaClinica {
  id                String   @id @default(cuid())
  pacienteId        String
  paciente          Paciente @relation(fields: [pacienteId], references: [id])
  
  procedimientoId   String?
  procedimiento     Procedimiento? @relation(fields: [procedimientoId], references: [id])
  
  // NUEVO: Vinculación con plantilla
  plantillaId       String?
  plantilla         PlantillaTemplate? @relation(fields: [plantillaId], references: [id])
  
  tipoHistoria      String   // ANAMNESIS, EXAMEN_FISICO, DIAGNOSTICO, PLAN, SEGUIMIENTO
  contenido         Json     // Campo flexible para datos dinámicos
  version           Int      @default(1)
  
  editadoPor        String
  usuario           User     @relation(fields: [editadoPor], references: [id])
  
  fechaCreacion     DateTime @default(now())
  fechaUltimaEdicion DateTime @updatedAt
  
  firmadoPorMedico  Boolean  @default(false)
  fechaFirma        DateTime?
  
  hashIntegridad    String   // SHA-256 para auditoría
  
  @@index([pacienteId])
  @@index([procedimientoId])
  @@index([plantillaId])
  @@index([tipoHistoria])
  @@index([fechaCreacion])
}

// ============================================
// PLANTILLAS POR PROCEDIMIENTO
// ============================================

model PlantillaProcedimiento {
  id                          String   @id @default(cuid())
  codigoCups                  String   @unique
  nombreProcedimiento         String
  categoria                   String   // FACIAL, CORPORAL, NO_INVASIVO
  descripcion                 String?
  
  camposObligatorios          Json     // Array de FormField
  camposOpcionales            Json     // Array de FormField
  
  riesgosAuto                 String[] // Array de riesgos por defecto
  complicacionesEsperadas     String[] // Array de complicaciones
  medicacionRecomendada       Json     // Array de medicamentos
  
  postoperatorioPorDias       Json     // Estructura de seguimiento por días
  
  consentimientoTemplate      String   // HTML del consentimiento
  
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  
  @@index([categoria])
}

// ============================================
// CONSENTIMIENTO INFORMADO
// ============================================

model Consentimiento {
  id                String   @id @default(cuid())
  pacienteId        String
  paciente          Paciente @relation(fields: [pacienteId], references: [id])
  
  procedimientoId   String
  procedimiento     Procedimiento @relation(fields: [procedimientoId], references: [id])
  
  plantillaId       String
  
  contenidoHtml     String
  contenidoPdfUrl   String?
  
  firmaDigitalUrl   String?   // URL de imagen de firma
  selfieUrl         String?   // URL de selfie
  
  fechaFirma        DateTime?
  
  ipDispositivo     String?
  navegador         String?
  sistemaOperativo  String?
  geolocation       Json?     // {latitude, longitude}
  
  firmado           Boolean   @default(false)
  hashIntegridad    String    // SHA-256
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([pacienteId])
  @@index([procedimientoId])
  @@index([firmado])
}

// ============================================
// FOTOS CLÍNICAS
// ============================================

model FotoClinica {
  id                String   @id @default(cuid())
  pacienteId        String
  paciente          Paciente @relation(fields: [pacienteId], references: [id])
  
  procedimientoId   String?
  procedimiento     Procedimiento? @relation(fields: [procedimientoId], references: [id])
  
  tipo              String   // ANTES, DESPUES, SEGUIMIENTO
  diasPostOperatorio Int?
  
  urlOriginal       String
  urlComprimida     String
  urlMiniatura      String
  
  metadatos         Json?    // {fecha, hora, dispositivo}
  anotaciones       Json?    // Array de anotaciones clínicas
  
  visibleAlPaciente Boolean  @default(false)
  
  fechaCaptura      DateTime
  createdAt         DateTime @default(now())
  
  @@index([pacienteId])
  @@index([procedimientoId])
  @@index([tipo])
}

// ============================================
// MAPA CORPORAL INTERACTIVO
// ============================================

model MapaCorporal {
  id                String   @id @default(cuid())
  pacienteId        String
  paciente          Paciente @relation(fields: [pacienteId], references: [id])
  
  procedimientoId   String
  procedimiento     Procedimiento @relation(fields: [procedimientoId], references: [id])
  
  fechaEvaluacion   DateTime
  
  zonasMarcadas     Json     // GeoJSON de zonas
  edemaZonas        Json     // {zona, severidad, colorCode}
  fibrosisZonas     Json     // {zona, presente, descripcion}
  dolorZonas        Json     // {zona, escala, tipo}
  
  colorIndicator    String?
  anotacionesClinics String?
  
  evaluadoPor       String
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([pacienteId])
  @@index([procedimientoId])
}

// ============================================
// SEGUIMIENTO POSTOPERATORIO
// ============================================

model SeguimientoPostOp {
  id                      String   @id @default(cuid())
  pacienteId              String
  paciente                Paciente @relation(fields: [pacienteId], references: [id])
  
  procedimientoId         String
  procedimiento           Procedimiento @relation(fields: [procedimientoId], references: [id])
  
  diaPostOp               Int
  fechaPrevista           DateTime
  fechaCompletada         DateTime?
  
  tipoSeguimiento         String   // CHECKLIST, FOTOS, CONTROL, EVALUACION
  
  checklistPreguntas      Json     // Array de preguntas
  checklistRespuestas     Json?    // Respuestas del paciente
  
  reportarComplicacion    Boolean  @default(false)
  descripcionComplicacion String?
  
  alertasGeneradas        Json[]   // Array de alertas
  
  completado              Boolean  @default(false)
  notificacionWhatsappEnviada Boolean @default(false)
  
  createdAt               DateTime @default(now())
  
  @@index([pacienteId])
  @@index([procedimientoId])
  @@index([diaPostOp])
  @@index([completado])
}

// ============================================
// ALERTAS CLÍNICAS
// ============================================

model Alerta {
  id                  String   @id @default(cuid())
  pacienteId          String
  paciente            Paciente @relation(fields: [pacienteId], references: [id])
  
  procedimientoId     String?
  procedimiento       Procedimiento? @relation(fields: [procedimientoId], references: [id])
  
  tipoAlerta          String   // RIESGO, COMPLICACION, CONTROL_PENDIENTE, MEDICACION
  severidad           String   // CRITICA, ALTA, MEDIA, BAJA
  
  descripcion         String
  accionRecomendada   String
  
  iaDetectada         Boolean  @default(false)
  
  resuelta            Boolean  @default(false)
  fechaResolucion     DateTime?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([pacienteId])
  @@index([severidad])
  @@index([resuelta])
}

// ============================================
// CITAS / AGENDA
// ============================================

model Cita {
  id                String   @id @default(cuid())
  pacienteId        String
  paciente          Paciente @relation(fields: [pacienteId], references: [id])
  
  medicoId          String
  medico            User     @relation(fields: [medicoId], references: [id])
  
  tipoCita          String   // CONSULTA, PREOPERATORIO, POSTOPERATORIO, CONTROL
  
  fechaHora         DateTime
  duracionMinutos   Int      @default(60)
  
  estado            String   @default("PENDIENTE") // PENDIENTE, CONFIRMADA, EN_SALA, COMPLETADA, CANCELADA
  
  motivo            String?
  notas             String?
  
  recordatorioWhatsapp Boolean @default(false)
  asistencia        Boolean?
  
  salaQuirofanoId   String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([pacienteId])
  @@index([medicoId])
  @@index([fechaHora])
  @@index([estado])
}

// ============================================
// TRANSACCIONES / FACTURACIÓN
// ============================================

model Transaccion {
  id              String   @id @default(cuid())
  pacienteId      String
  paciente        Paciente @relation(fields: [pacienteId], references: [id])
  
  procedimientoId String?
  
  tipo            String   // CARGO, PAGO, ABONO
  concepto        String
  
  monto           Float
  moneda          String   @default("COP")
  
  metodoPago      String   // EFECTIVO, TARJETA, TRANSFER, OTRO
  referenciaPago  String?
  
  estado          String   @default("PENDIENTE")
  
  reciboUrl       String?
  
  creadoPor       String
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([pacienteId])
  @@index([estado])
}

// ============================================
// LOGS DE AUDITORÍA
// ============================================

model AuditLog {
  id              String   @id @default(cuid())
  usuarioId       String
  usuario         User     @relation(fields: [usuarioId], references: [id])
  
  tablaAfectada   String
  registroId      String
  
  tipoOperacion   String   // CREATE, UPDATE, DELETE, VIEW
  
  datosAntes      Json?
  datosDespues    Json?
  
  ipOrigen        String?
  userAgent       String?
  razon           String?
  
  timestamp       DateTime @default(now())
  
  @@index([usuarioId])
  @@index([tablaAfectada])
  @@index([timestamp])
}

// ============================================
// INTEGRACIONES
// ============================================

model Integracion {
  id              String   @id @default(cuid())
  tipo            String   // WHATSAPP, GOOGLE_CALENDAR, STRIPE, OPENAI
  
  credencialesEncriptadas String
  activa          Boolean  @default(true)
  
  fechaUltimaSincronizacion DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// PROCEDIMIENTOS CUPS - MAESTRO PARAMETRIZABLE
// ============================================

model ProcedimientoCUPS {
  id                  String    @id @default(cuid())
  codigoCUPS          String    @unique
  nombre              String    // "Rinoplastia", "Liposucción", etc
  descripcion         String?
  
  tipoCategoria       String    // "Facial", "Corporal", "No-invasivo"
  riesgoNivel         String    // "Bajo", "Medio", "Alto"
  
  diasSeguimiento     Int       @default(30)  // cuántos días seguimiento automático
  
  // Datos JSON para flexibilidad
  datosAdicionales    Json?
  
  activo              Boolean   @default(true)
  
  // Relaciones
  plantillas          PlantillaTemplate[]
  checklistTemplates  ChecklistTemplate[]
  consentimientosTemplate ConsentimientoTemplate[]
  procedimientosClinica Procedimiento[]  // Procedimientos clínicos asociados
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@index([codigoCUPS])
  @@index([tipoCategoria])
  @@index([activo])
}

// ============================================
// PLANTILLAS PARAMETRIZABLES POR CUPS
// ============================================

model PlantillaTemplate {
  id                  String    @id @default(cuid())
  codigoCUPS          String
  procedimiento       ProcedimientoCUPS @relation(fields: [codigoCUPS], references: [codigoCUPS], onDelete: Cascade)
  
  nombre              String    // "Historia Clínica", "Evaluación Pre-op", etc
  tipo                String    // "historia-clinica", "evaluacion", "seguimiento"
  descripcion         String?
  
  // Estructura dinámica de secciones
  seccionesJSON       Json      // Array de secciones: [{id, nombre, campos: []}]
  
  // Configuración
  requiereSignatura   Boolean   @default(false)
  requiereFoto        Boolean   @default(false)
  requiereMapaCorporal Boolean  @default(false)
  
  ordenVisualizacion  Int       @default(1)
  activa              Boolean   @default(true)
  
  // Auditoría
  creadoPor           String?
  actualizadoPor      String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Relaciones
  historiasClinicas   HistoriaClinica[]
  
  @@unique([codigoCUPS, tipo])
  @@index([codigoCUPS])
  @@index([tipo])
}

// ============================================
// CHECKLIST DINÁMICO POR FASES
// ============================================

model ChecklistTemplate {
  id                  String    @id @default(cuid())
  codigoCUPS          String
  procedimiento       ProcedimientoCUPS @relation(fields: [codigoCUPS], references: [codigoCUPS], onDelete: Cascade)
  
  fase                String    // "pre-operatorio", "intra-operatorio", "post-operatorio"
  nombre              String    // "Checklist Pre-op", etc
  
  // Array de items: [{id, label, requerido, orden, tipo}]
  itemsJSON           Json
  
  // Alertas automáticas por día
  // [{dia: 1, mensaje: "...", tipo: "info|warning|critical"}]
  alertasAutomaticasJSON Json?
  
  activo              Boolean   @default(true)
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@unique([codigoCUPS, fase])
  @@index([codigoCUPS])
}

// ============================================
// CONSENTIMIENTO DINÁMICO
// ============================================

model ConsentimientoTemplate {
  id                  String    @id @default(cuid())
  codigoCUPS          String
  procedimiento       ProcedimientoCUPS @relation(fields: [codigoCUPS], references: [codigoCUPS], onDelete: Cascade)
  
  titulo              String
  
  // Secciones dinámicas: [{id, titulo, contenido, requerido}]
  seccionesJSON       Json
  
  // Riesgos por CUPS: [{riesgo, probabilidad, severidad, descripcion}]
  riesgosJSON         Json
  
  // Recomendaciones pre/post: [{tipo, texto}]
  recomendacionesJSON Json?
  
  activo              Boolean   @default(true)
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@unique([codigoCUPS])
  @@index([codigoCUPS])
}

// ============================================
// CONFIGURACIÓN DEL SISTEMA
// ============================================

model ConfiguracionSistema {
  id                  String    @id @default(cuid())
  clave               String    @unique
  valor               Json
  descripcion         String?
  
  // Ejemplo:
  // clave: "whatsapp_token", valor: "{token: ...}"
  // clave: "dias_seguimiento_default", valor: "{dias: 30}"
  
  updatedAt           DateTime  @updatedAt
  
  @@index([clave])
}

// ============================================
// INSTANCIAS DE CHECKLISTS COMPLETADOS
// ============================================

model ChecklistCompletado {
  id                  String    @id @default(cuid())
  procedimientoId     String
  procedimiento       Procedimiento @relation(fields: [procedimientoId], references: [id], onDelete: Cascade)
  
  templateId          String
  
  fase                String    // copia de fase del template
  
  // Respuestas: [{itemId, respuesta, comentario}]
  respuestasJSON      Json?
  
  completadoEn        DateTime?
  completadoPor       String?   // User ID
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@index([procedimientoId])
  @@index([completadoEn])
}

// ============================================
// DISPONIBILIDAD DEL MÉDICO (CU-01)
// ============================================

model DisponibilidadMedico {
  id           String   @id @default(cuid())
  medicoId     String
  medico       User     @relation(fields: [medicoId], references: [id], onDelete: Cascade)

  diaSemana    Int      // 0=Dom, 1=Lun, 2=Mar, 3=Mié, 4=Jue, 5=Vie, 6=Sáb
  horaInicio   String   // "08:00"
  horaFin      String   // "18:00"
  duracionSlot Int      @default(60) // minutos por cita

  sede         String?  @default("Principal")
  tipoAtencion String?  @default("CONSULTA") // CONSULTA | PREOPERATORIO | POSTOPERATORIO | CONTROL
  consultorio  String?

  activo       Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([medicoId])
  @@index([diaSemana])
}

// ============================================
// BLOQUEOS DE AGENDA (vacaciones, festivos)
// ============================================

model BloqueDisponibilidad {
  id        String   @id @default(cuid())
  medicoId  String
  medico    User     @relation(fields: [medicoId], references: [id], onDelete: Cascade)

  fechaInicio DateTime
  fechaFin    DateTime
  motivo      String?  @default("Bloqueo")
  todoElDia   Boolean  @default(true)

  createdAt DateTime @default(now())

  @@index([medicoId])
  @@index([fechaInicio])
}

// ============================================
// MÓDULO: PARAMETRIZACIÓN DEL SISTEMA
// Consulta Externa – SARAI Admin
// ============================================

// 1. ESPECIALIDADES
model Especialidad {
  id                    String   @id @default(cuid())
  codigo                String   @unique
  nombre                String   @unique
  descripcion           String?
  aplicaAnestesia       Boolean  @default(false)
  aplicaPediatria       Boolean  @default(false)
  aplicaCirugia         Boolean  @default(false)
  aplicaInstrumentacion Boolean  @default(false)
  aplicaMedicoFamiliar  Boolean  @default(false)
  estado                Boolean  @default(true)
  usuarioCreacion       String?

  tiposConsulta         TipoConsulta[]
  preparaciones         Preparacion[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([estado])
}

// 2. HC MÓDULOS (Tipos de Historia Clínica)
model HCModulo {
  id                      String   @id @default(cuid())
  codigo                  String   @unique
  nombre                  String
  descripcion             String?
  activo                  Boolean  @default(true)
  tipoFinalidad           String?
  tipoRips                String?
  parametrosConfiguracion Json?
  programaId              String?
  usuarioCreacion         String?

  tiposConsulta           TipoConsulta[]

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([activo])
}

// 3. DEPARTAMENTOS
model Departamento {
  id          String   @id @default(cuid())
  codigo      String   @unique
  nombre      String
  descripcion String?
  estado      Boolean  @default(true)

  tiposConsulta  TipoConsulta[]
  reglas         ReglaOperativa[]
  departamentoCargos DepartamentoCargo[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([estado])
}

// 4. SERVICIOS FACTURABLES (catálogo CUPS para facturación)
model ServicioFacturable {
  id               String   @id @default(cuid())
  codigoCups       String   @unique
  nombre           String
  descripcion      String?
  categoria        String?
  subcategoria     String?
  tipoServicio     String?
  nivelComplejidad String?
  conceptoRips     String?
  precioBase       Float    @default(0)
  requiereCantidad Boolean  @default(false)
  esHonorario      Boolean  @default(false)
  esPOS            Boolean  @default(false)
  estado           Boolean  @default(true)

  configConsultas  ConfigServicioConsulta[]
  reglas           ReglaOperativa[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([estado])
  @@index([categoria])
}

// 5. TIPOS DE CONSULTA (núcleo)
model TipoConsulta {
  id                       String   @id @default(cuid())
  nombre                   String
  descripcion              String?

  especialidadId           String?
  especialidad             Especialidad?       @relation(fields: [especialidadId], references: [id])

  departamentoId           String?
  departamento             Departamento?       @relation(fields: [departamentoId], references: [id])

  hcModuloId               String?
  hcModulo                 HCModulo?           @relation(fields: [hcModuloId], references: [id])

  // Flags clínicos
  requiereCaja             Boolean  @default(false)
  manejaAnestesia          Boolean  @default(false)
  permiteAgendamiento      Boolean  @default(true)
  controlaTiempoCita       Boolean  @default(false)
  abreHistoriaClinica      Boolean  @default(true)
  permiteCargosAdicionales Boolean  @default(false)
  esProgramaPYP            Boolean  @default(false)
  manejaProtocolos         Boolean  @default(false)
  clasificacion            String   @default("CONSULTA") // CONSULTA, PROCEDIMIENTO, CIRUGIA, CONTROL
  esPsicologia             Boolean  @default(false)

  // Operativo
  duracionMinutos          Int      @default(30)
  bodegaId                 String?

  estado                   Boolean  @default(true)
  usuarioCreacion          String?

  serviciosConfig          ConfigServicioConsulta[]
  preparaciones            Preparacion[]

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([especialidadId])
  @@index([estado])
}

// 6. CONFIGURACIÓN DE SERVICIOS POR CONSULTA
model ConfigServicioConsulta {
  id                String   @id @default(cuid())
  tipoConsultaId    String
  tipoConsulta      TipoConsulta       @relation(fields: [tipoConsultaId], references: [id], onDelete: Cascade)
  servicioId        String
  servicio          ServicioFacturable @relation(fields: [servicioId], references: [id])

  esPrincipal       Boolean  @default(false)
  generaAutomatico  Boolean  @default(false)
  requiereOrden     Boolean  @default(false)
  centroOperacionId String?
  cuentaContable    String?
  hcModuloId        String?
  usuarioCreacion   String?

  createdAt         DateTime @default(now())

  @@unique([tipoConsultaId, servicioId])
  @@index([tipoConsultaId])
  @@index([servicioId])
}

// 7. REGLAS OPERATIVAS (Departamento × Servicio)
model ReglaOperativa {
  id                     String   @id @default(cuid())
  departamentoId         String
  departamento           Departamento       @relation(fields: [departamentoId], references: [id], onDelete: Cascade)
  servicioId             String
  servicio               ServicioFacturable @relation(fields: [servicioId], references: [id])

  permiteSeleccion       Boolean  @default(true)
  manejaInsumos          Boolean  @default(false)
  generaOrden            Boolean  @default(false)
  liquidaHonorarios      Boolean  @default(false)
  cumplimientoAutomatico Boolean  @default(false)
  tomadoAutomatico       Boolean  @default(false)
  cumplimientoParcial    Boolean  @default(false)
  manejaCentroCosto      Boolean  @default(false)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([departamentoId, servicioId])
  @@index([departamentoId])
}

// 8. PREPARACIONES / RECOMENDACIONES
model Preparacion {
  id               String   @id @default(cuid())
  nombre           String
  descripcion      String?
  tipo             String   @default("consulta") // consulta | procedimiento
  especialidadId   String?
  especialidad     Especialidad?  @relation(fields: [especialidadId], references: [id])
  tipoConsultaId   String?
  tipoConsulta     TipoConsulta?  @relation(fields: [tipoConsultaId], references: [id])
  estado           Boolean  @default(true)
  usuarioCreacion  String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([estado])
  @@index([tipoConsultaId])
}

// 9. CARGOS DE CONSULTA EXTERNA
// Conceptos de cobro adicionales que se pueden aplicar en la consulta
model Cargo {
  id               String   @id @default(cuid())
  codigo           String   @unique
  nombre           String
  descripcion      String?
  // CONSULTA | PROCEDIMIENTO | CIRUGIA | ADMINISTRATIVO | HONORARIO | INSUMO
  tipo             String   @default("CONSULTA")
  // Valor base en COP
  valor            Float    @default(0)
  // Unidad de medida
  unidad           String?  // unidad, sesion, hora, etc.
  // Código CUPS o interno de referencia
  codigoReferencia String?
  // Si aplica IVA
  aplicaIva        Boolean  @default(false)
  tasaIva          Float    @default(0)
  // Si es obligatorio o se agrega a elección
  esObligatorio    Boolean  @default(false)
  // Si aplica para paciente PyP
  aplicaPYP        Boolean  @default(false)
  estado           Boolean  @default(true)
  usuarioCreacion  String?

  departamentoCargos DepartamentoCargo[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([estado])
  @@index([tipo])
}

// 10. TIPOS DE CONSULTORIO
model TipoConsultorio {
  id               String   @id @default(cuid())
  codigo           String   @unique
  tipoConsultorio  String
  descripcion      String?
  indiceAutomatico Int?
  estado           Boolean  @default(true)
  usuarioCreacion  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@index([estado])
}

// 11. DEPARTAMENTO x CARGO (reglas operativas)
model DepartamentoCargo {
  id                     String       @id @default(cuid())
  departamentoId         String
  departamento           Departamento @relation(fields: [departamentoId], references: [id], onDelete: Cascade)
  cargoId                String
  cargo                  Cargo        @relation(fields: [cargoId], references: [id])
  permiteSeleccion       Boolean      @default(true)
  manejaInsumos          Boolean      @default(false)
  cumplimientoAutomatico Boolean      @default(false)
  tomadoAutomatico       Boolean      @default(false)
  interfaceExterno       Boolean      @default(false)
  generaOrden            Boolean      @default(false)
  liquidaHonorarios      Boolean      @default(false)
  cumplimientoParcial    Boolean      @default(false)
  manejaCentroCosto      Boolean      @default(false)
  usuarioCreacion        String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  @@unique([departamentoId, cargoId])
  @@index([departamentoId])
}

// ============================================
// CAMPOS DEL FORMULARIO DE PACIENTE
// ============================================

model CampoPaciente {
  id              String   @id @default(cuid())
  nombre          String   @unique  // key interno: primerNombre, numeroCelular, etc.
  etiqueta        String            // label visible: "Primer Nombre"
  seccion         String            // documentacion | personal | contacto | laboral | demografico | consulta | salud | notas
  tipoCampo       String   @default("text") // text | select | date | tel | email | textarea | number
  esVisible       Boolean  @default(true)
  esObligatorio   Boolean  @default(false)
  esPersonalizado Boolean  @default(false)  // true = creado desde Admin, no viene del form original
  opciones        Json?             // [{value, label}] para tipoCampo = select
  placeholder     String?
  orden           Int      @default(0)
  estado          Boolean  @default(true)
  usuarioCreacion String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([seccion])
  @@index([esVisible])
  @@index([esPersonalizado])
}

// ============================================
// PARAMETRIZACIÓN GENERAL DEL SISTEMA
// ============================================

// Parámetros clave-valor por grupo (clinica | agenda)
model ParametroSistema {
  id        String   @id @default(cuid())
  grupo     String   // clinica | agenda
  clave     String   // nombre_clinica | duracion_default | etc.
  valor     String   @default("")
  etiqueta  String   // label visible en el formulario
  tipo      String   @default("text") // text | number | time | boolean | email | url | tel
  orden     Int      @default(0)
  estado    Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([grupo, clave])
  @@index([grupo])
}

// Listas de valores para los campos select del formulario de paciente
model ListaValor {
  id        String   @id @default(cuid())
  grupo     String   // tipoDocumento | generoBiologico | estadoCivil | grupoEtnico | nivelEducacion | orientacionSexual | discapacidad | formaAsignacion | generoSentido
  valor     String
  etiqueta  String
  orden     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([grupo, valor])
  @@index([grupo])
}

// Motivos de cita / cancelación / reprogramación
model MotivoCita {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  tipo        String   @default("consulta") // consulta | control | preoperatorio | seguimiento | cancelacion
  orden       Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tipo])
  @@index([activo])
}
