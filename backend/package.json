{
  "name": "estegia-backend",
  "version": "1.0.0",
  "description": "Backend API para Historia Clínica Estética Inteligente",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"node --loader ts-node/esm src/index.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext ts",
    "migrate": "prisma migrate dev",
    "seed": "node --loader ts-node/esm prisma/seed.ts",
    "setup-disp": "node --loader ts-node/esm setup-disponibilidad.ts",
    "generate": "prisma generate",
    "test": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --config jest.config.cjs",
    "test:watch": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --config jest.config.cjs --watch"
  },
  "dependencies": {
    "@prisma/client": "^5.5.2",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "openai": "^4.25.0",
    "pdfkit": "^0.13.0",
    "puppeteer": "^25.0.4",
    "sharp": "^0.33.0",
    "socket.io": "^4.7.2",
    "stripe": "^14.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.9.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.5.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
