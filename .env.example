# ============================================
# ESTEGIA - VARIABLES DE ENTORNO
# ============================================
# Copiar este archivo a .env y llenar con valores reales

# ============================================
# BASE DE DATOS
# ============================================

# PostgreSQL
DATABASE_URL="postgresql://estegia_user:secure_password_123@localhost:5432/estegia"

# MongoDB
MONGODB_URL="mongodb://admin:password@localhost:27017/estegia?authSource=admin"

# Redis
REDIS_URL="redis://localhost:6379"

# ============================================
# JWT Y AUTENTICACIÓN
# ============================================

JWT_SECRET="tu-clave-super-secreta-minimo-32-caracteres-aleatorios-aqui"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="30d"

# Bcrypt
BCRYPT_ROUNDS=10

# ============================================
# APLICACIÓN
# ============================================

NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:5173"
LOG_LEVEL="debug"

# ============================================
# SERVICIOS EXTERNOS - OPENAI (IA)
# ============================================

OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxx"
OPENAI_MODEL="gpt-4-turbo"

# Whisper (para dictado)
OPENAI_WHISPER_MODEL="whisper-1"

# ============================================
# PAGOS - STRIPE
# ============================================

STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxx"
STRIPE_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_test_xxxxxxxxxxxxxxxxxxxxx"

# Para moneda local
STRIPE_CURRENCY="cop"

# ============================================
# WHATSAPP Y SMS - TWILIO
# ============================================

TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxx"
TWILIO_WHATSAPP_NUMBER="+1234567890"
TWILIO_SMS_NUMBER="+1234567890"

# ============================================
# ALMACENAMIENTO - AWS S3
# ============================================

AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIXXXXXXXXXXXXXXXXXXXXX"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxx"
AWS_S3_BUCKET="estegia-production"

# URL pública de S3 (si está configurado)
AWS_S3_PUBLIC_URL="https://estegia-production.s3.amazonaws.com"

# ============================================
# EMAIL - SMTP
# ============================================

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="noreply@estegia.com"
SMTP_PASS="xxxxxxxxxxxxxxxxxxxxx"
SMTP_FROM_NAME="EstetIA"
SMTP_FROM_EMAIL="noreply@estegia.com"

# ============================================
# FRONTEND - VARIABLES DE ENTORNO
# ============================================

# Crear archivo .env.local en frontend/

VITE_API_URL="http://localhost:3001/api"
VITE_WS_URL="ws://localhost:3001"

VITE_STRIPE_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxx"

# Google Maps (si se implementa)
VITE_GOOGLE_MAPS_API_KEY="AIzaxxxxxxxxxxxxxxxxxxxxx"

# Google Analytics
VITE_GA_ID="G-XXXXXXXXXX"

# ============================================
# SEGURIDAD
# ============================================

# CORS
ALLOWED_ORIGINS="http://localhost:5173,https://app.estegia.com"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET="tu-sesion-secret-super-seguro"
SESSION_TIMEOUT=1800000  # 30 minutos en ms

# ============================================
# CONFIGURACIÓN DE LOGS
# ============================================

LOG_LEVEL="debug"  # debug, info, warn, error
LOG_FILE="./logs/app.log"
LOG_MAX_SIZE="10m"
LOG_MAX_FILES=5

# ============================================
# CONFIGURACIÓN DE BACKUP
# ============================================

BACKUP_SCHEDULE="0 2 * * *"  # 2 AM diariamente
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE="s3"  # s3 o local

# ============================================
# CONFIGURACIÓN DE CRON JOBS
# ============================================

# WhatsApp reminders
WHATSAPP_REMINDER_SCHEDULE="0 10 * * *"  # 10 AM

# Seguimiento automático
SEGUIMIENTO_AUTO_SCHEDULE="0 8 * * *"  # 8 AM

# Backup de BD
BACKUP_DB_SCHEDULE="0 2 * * *"  # 2 AM

# ============================================
# CONFIGURACIÓN DE TESTING
# ============================================

NODE_ENV_TEST="test"
TEST_DATABASE_URL="postgresql://estegia_user:password@localhost:5432/estegia_test"

# ============================================
# FEATURES FLAGS
# ============================================

FEATURE_WHATSAPP_INTEGRATION=true
FEATURE_IA_ANALYSIS=true
FEATURE_VIDEO_CONSENT=false  # Futuro
FEATURE_BLOCKCHAIN_CONSENT=false  # Futuro
FEATURE_TELEMEDICINE=false  # Futuro

# ============================================
# URLS Y ENDPOINTS
# ============================================

# Para links en emails, etc
APP_URL="http://localhost:5173"
API_URL="http://localhost:3001/api"

# Para webhooks
WEBHOOK_URL="http://localhost:3001/webhooks"

# ============================================
# NOTAS IMPORTANTES
# ============================================

# 1. NUNCA commitear este archivo con valores reales a Git
# 2. Usar .env.example como plantilla
# 3. En producción, usar variables de entorno del servidor
# 4. Cambiar todos los valores de 'xxxx' con valores reales
# 5. Usar claves fuertes (mínimo 32 caracteres para JWT_SECRET)
# 6. Rotar claves regularmente
# 7. Usar secrets manager (AWS Secrets Manager, Vault, etc.) en prod

# ============================================
# COMANDOS ÚTILES
# ============================================

# Generar JWT_SECRET seguro:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Generar SESSION_SECRET seguro:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
