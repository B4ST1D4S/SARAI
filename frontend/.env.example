# Variables de entorno para el Frontend (Vite)
# Copiar este archivo a .env y completar con valores reales
# IMPORTANTE: En Vercel, configurar estas variables en:
#   Project Settings → Environment Variables

# URL del backend desplegado en Vercel
# En desarrollo usa el proxy de vite (localhost:3001)
# En producción apunta al backend de Vercel
VITE_API_URL=https://sarai-backend.vercel.app/api
